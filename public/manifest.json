{
  "manifest_version": 3,
  "name": "Theme Generator",
  "version": "0.1.0",
  "description": "Inject AI-generated themes into any website",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Theme Generator"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
