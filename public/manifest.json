{
  "manifest_version": 3,
  "name": "Theme Generator",
  "version": "0.1.0",
  "description": "Inject AI-generated themes into any website",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://nano-claude-theme-manager.reneebe.workers.dev/*",
    "https://magiclink.reneebe.workers.dev/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Theme Generator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://magiclink.reneebe.workers.dev/*"],
      "js": ["magiclink-sync.js"],
      "run_at": "document_idle"
    }
  ]
}
